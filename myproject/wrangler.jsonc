// Cloudflare Worker configuration for Lisa 1000
// - Static frontend served from ./public (same files Express serves)
// - API routes handled by worker/index.js
// Secrets (ANTHROPIC_API_KEY, OPENAI_API_KEY, HF_CREDENTIALS) are NOT set here:
//   local dev  -> .dev.vars file (gitignored)
//   production -> `npx wrangler secret put <NAME>`
{
    "name": "lisa1000",
    "main": "worker/index.js",
    "compatibility_date": "2026-07-01",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "./public"
    }
}
